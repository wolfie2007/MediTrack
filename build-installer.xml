<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.meditrack</groupId>
  <artifactId>meditrack</artifactId>
  <version>1.0.0</version>
  <name>MediTrack</name>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>17</maven.compiler.release>
    <javafx.version>21.0.3</javafx.version>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-controls</artifactId>
      <version>${javafx.version}</version>
    </dependency>
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-fxml</artifactId>
      <version>${javafx.version}</version>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.11.0</version>
        <configuration>
          <release>17</release>
        </configuration>
      </plugin>

      <!-- Create FAT JAR -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-assembly-plugin</artifactId>
        <version>3.6.0</version>
        <configuration>
          <descriptorRefs>
            <descriptorRef>jar-with-dependencies</descriptorRef>
          </descriptorRefs>
          <archive>
            <manifest>
              <mainClass>com.meditrack.Main</mainClass>
              <addClasspath>true</addClasspath>
            </manifest>
          </archive>
          <finalName>MediTrack</finalName>
          <appendAssemblyId>false</appendAssemblyId>
        </configuration>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>single</goal>
            </goals>
          </execution>
        </executions>
      </plugin>

      <!-- Create portable standalone installer -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-antrun-plugin</artifactId>
        <version>3.1.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>run</goal>
            </goals>
            <configuration>
              <target>
                <echo message="Creating portable installer package..." />
                <mkdir dir="${project.build.directory}/meditrack-portable" />
                <copy file="${project.build.directory}/MediTrack.jar" 
                      todir="${project.build.directory}/meditrack-portable" />
                <copy file="${basedir}/run.bat" 
                      todir="${project.build.directory}/meditrack-portable" />
                <copy file="${basedir}/run.sh" 
                      todir="${project.build.directory}/meditrack-portable" />
                <chmod file="${project.build.directory}/meditrack-portable/run.sh" perm="755" />
                <copy file="${basedir}/README-PORTABLE.md" 
                      todir="${project.build.directory}/meditrack-portable" />
                <zip destfile="${project.build.directory}/MediTrack-Portable.zip" 
                     basedir="${project.build.directory}/meditrack-portable" />
                <echo message="Portable package created: MediTrack-Portable.zip" />
              </target>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
