<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<!-- Tooltip removed -->
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.meditrack.ui.PrescriptionManagerController" spacing="20">
    <HBox spacing="12" styleClass="page-header">
        <VBox spacing="4">
            <Label text="Prescription Manager" styleClass="page-title" />
            <Label text="Link doctors, patients, and medicines" styleClass="body" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="New Prescription" styleClass="ghost-button" onAction="#clearForm" />
    </HBox>

    <HBox spacing="18">
        <VBox spacing="10" styleClass="panel" HBox.hgrow="ALWAYS">
            <HBox spacing="8">
                <Label text="Prescriptions" styleClass="section-title" />
                <Label fx:id="countLabel" text="0 saved" styleClass="muted" />
            </HBox>
            <TableView fx:id="prescriptionTable" prefHeight="420" styleClass="schedule-table">
                <columns>
                    <TableColumn fx:id="patientColumn" text="Patient" prefWidth="160" />
                    <TableColumn fx:id="doctorColumn" text="Doctor" prefWidth="160" />
                    <TableColumn fx:id="medicineColumn" text="Medicine" prefWidth="160" />
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
                    <TableColumn fx:id="periodColumn" text="Period" prefWidth="160" />
                </columns>
            </TableView>
        </VBox>

        <ScrollPane fitToWidth="true" styleClass="panel" prefWidth="320" vbarPolicy="ALWAYS" HBox.hgrow="NEVER">
            <VBox spacing="12" styleClass="details-panel">
                <Label text="Prescription Details" styleClass="section-title" />
                <VBox spacing="6">
                    <Label text="Patient" styleClass="input-label" />
                    <ChoiceBox fx:id="patientChoice" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Doctor" styleClass="input-label" />
                    <ChoiceBox fx:id="doctorChoice" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Medicine" styleClass="input-label" />
                    <ChoiceBox fx:id="medicineChoice" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Instructions" styleClass="input-label" />
                    <TextArea fx:id="instructionsArea" prefRowCount="3" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Start Date" styleClass="input-label" />
                    <DatePicker fx:id="startDatePicker" />
                </VBox>
                <VBox spacing="6">
                    <Label text="End Date" styleClass="input-label" />
                    <DatePicker fx:id="endDatePicker" />
                </VBox>
                <CheckBox fx:id="activeCheck" text="Active prescription" />
                <HBox spacing="10">
                    <Button text="Save" styleClass="primary-button" onAction="#savePrescription" />
                    <Button text="Delete" styleClass="ghost-button" onAction="#deletePrescription" />
                </HBox>
            </VBox>
        </ScrollPane>
    </HBox>
</VBox>
