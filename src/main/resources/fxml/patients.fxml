<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<!-- Tooltip removed -->
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.meditrack.ui.PatientProfilesController" spacing="20">
    <HBox spacing="12" styleClass="page-header">
        <VBox spacing="4">
            <Label text="Patient Profiles" styleClass="page-title" />
            <Label text="Add and manage family member profiles" styleClass="body" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="New Profile" styleClass="ghost-button" onAction="#clearForm" />
    </HBox>

    <HBox spacing="18">
        <VBox spacing="10" styleClass="panel" HBox.hgrow="ALWAYS">
            <HBox spacing="8">
                <Label text="Profiles" styleClass="section-title" />
                <Label fx:id="countLabel" text="0 saved" styleClass="muted" />
            </HBox>
            <TableView fx:id="profilesTable" prefHeight="420" styleClass="schedule-table">
                <columns>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="120" />
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="160" />
                    <TableColumn fx:id="relationshipColumn" text="Relationship" prefWidth="140" />
                    <TableColumn fx:id="dobColumn" text="DOB" prefWidth="120" />
                    <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="140" />
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="12" styleClass="panel" prefWidth="320">
            <Label text="Profile Details" styleClass="section-title" />
            <VBox spacing="6">
                <Label text="Profile Type" styleClass="input-label" />
                <ChoiceBox fx:id="typeChoice" />
            </VBox>
            <VBox spacing="6">
                <Label text="Full Name" styleClass="input-label" />
                <TextField fx:id="nameField" promptText="Full name" />
            </VBox>
            <VBox spacing="6">
                <Label text="Relationship" styleClass="input-label" />
                <TextField fx:id="relationshipField" promptText="Only for family members" />
            </VBox>
            <VBox spacing="6">
                <Label text="Date of Birth" styleClass="input-label" />
                <DatePicker fx:id="dobPicker" />
            </VBox>
            <VBox spacing="6">
                <Label text="Phone" styleClass="input-label" />
                <TextField fx:id="phoneField" promptText="Phone" />
            </VBox>
            <VBox spacing="6">
                <Label text="Email" styleClass="input-label" />
                <TextField fx:id="emailField" promptText="Email" />
            </VBox>
            <HBox spacing="10">
                <Button text="Save" styleClass="primary-button" onAction="#saveProfile" />
                <Button text="Delete" styleClass="ghost-button" onAction="#deleteProfile" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
