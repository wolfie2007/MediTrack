<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<!-- Tooltip removed -->
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.meditrack.ui.DashboardController" spacing="20">
    <HBox spacing="12" styleClass="page-header">
        <VBox spacing="4">
            <Label text="Dashboard" styleClass="page-title" />
            <Label text="Today at a glance" styleClass="body" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="todayLabel" text="" styleClass="chip" />
    </HBox>

    <HBox spacing="16" styleClass="stats-row">
        <VBox spacing="6" styleClass="stat-card">
            <Label text="Streak" styleClass="stat-label" />
            <Label fx:id="streakLabel" text="0 days" styleClass="stat-value" />
            <Label text="On-time doses" styleClass="muted" />
        </VBox>
        <VBox spacing="6" styleClass="stat-card">
            <Label text="Doses today" styleClass="stat-label" />
            <Label fx:id="dosesTodayLabel" text="0" styleClass="stat-value" />
            <Label fx:id="dosesTodayMeta" text="0 taken, 0 due" styleClass="muted" />
        </VBox>
        <VBox spacing="6" styleClass="stat-card">
            <Label text="Low stock" styleClass="stat-label" />
            <Label fx:id="lowStockLabel" text="0" styleClass="stat-value" />
            <Label text="Refill reminders" styleClass="muted" />
        </VBox>
    </HBox>

    <VBox spacing="10" styleClass="panel">
        <HBox spacing="8">
            <Label text="Today's schedule" styleClass="section-title" />
            <Label fx:id="scheduleMeta" text="0 doses planned" styleClass="muted" />
        </HBox>
        <TableView fx:id="scheduleTable" prefHeight="320" styleClass="schedule-table">
            <columns>
                <TableColumn fx:id="timeColumn" text="Time" prefWidth="110" />
                <TableColumn fx:id="patientColumn" text="Patient" prefWidth="160" />
                <TableColumn fx:id="medicineColumn" text="Medicine" prefWidth="200" />
                <TableColumn fx:id="doseColumn" text="Dose" prefWidth="140" />
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="120" />
            </columns>
        </TableView>
    </VBox>
</VBox>
