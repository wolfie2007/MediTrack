<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<!-- Tooltip removed -->
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.meditrack.ui.MedicineManagementController" spacing="20">
    <HBox spacing="12" styleClass="page-header">
        <VBox spacing="4">
            <Label text="Medicine Management" styleClass="page-title" />
            <Label text="Track medicines, stock, and duration" styleClass="body" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="New Medicine" styleClass="ghost-button" onAction="#clearForm" />
    </HBox>

    <HBox spacing="18">
        <VBox spacing="10" styleClass="panel" HBox.hgrow="ALWAYS">
            <HBox spacing="8">
                <Label text="Medicines" styleClass="section-title" />
                <Label fx:id="countLabel" text="0 saved" styleClass="muted" />
            </HBox>
            <TableView fx:id="medicineTable" prefHeight="420" styleClass="schedule-table">
                <columns>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="110" />
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="180" />
                    <TableColumn fx:id="dosageColumn" text="Dosage" prefWidth="140" />
                    <TableColumn fx:id="stockColumn" text="Stock" prefWidth="100" />
                    <TableColumn fx:id="durationColumn" text="Duration" prefWidth="160" />
                </columns>
            </TableView>
        </VBox>

        <ScrollPane fitToWidth="true" styleClass="panel" prefWidth="320" vbarPolicy="ALWAYS" HBox.hgrow="NEVER">
            <VBox spacing="12" styleClass="details-panel">
                <Label text="Medicine Details" styleClass="section-title" />
                <VBox spacing="6">
                    <Label text="Type" styleClass="input-label" />
                    <ChoiceBox fx:id="typeChoice" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Name" styleClass="input-label" />
                    <TextField fx:id="nameField" promptText="Medicine name" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Dosage" styleClass="input-label" />
                    <TextField fx:id="dosageField" promptText="Dosage" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Stock" styleClass="input-label" />
                    <TextField fx:id="stockField" promptText="Stock count" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Start Date" styleClass="input-label" />
                    <DatePicker fx:id="startDatePicker" />
                </VBox>
                <VBox spacing="6">
                    <Label text="End Date" styleClass="input-label" />
                    <DatePicker fx:id="endDatePicker" />
                </VBox>
                <VBox spacing="6">
                    <Label text="Extra" styleClass="input-label" />
                    <TextField fx:id="extraField" promptText="Strength / Flavor / Site" />
                </VBox>
                <HBox spacing="10">
                    <Button text="Save" styleClass="primary-button" onAction="#saveMedicine" />
                    <Button text="Delete" styleClass="ghost-button" onAction="#deleteMedicine" />
                </HBox>
            </VBox>
        </ScrollPane>
    </HBox>
</VBox>
